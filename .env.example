# Copy this file to `.env` in the same directory (never commit `.env`).

# Base URL for the health platform API (default port 3111).
API_BASE_URL=http://localhost:3111

# KYC flow: true/1/yes enables KYC gating; false/0/no (default) sends doctors straight to dashboard.
FEATURE_KYC_ENABLED=false

# Clinical scribe (WebSocket to clinical-scribe relay, default port 8090). Android emulator: ws://10.0.2.2:8090
FEATURE_SCRIBE_ENABLED=false
SCRIBE_WS_BASE_URL=ws://localhost:8090
